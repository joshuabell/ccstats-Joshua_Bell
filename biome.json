{
  "$schema": "https://biomejs.dev/schemas/2.4.12/schema.json",
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 120
  },
  "files": {
    "includes": ["**", "!**/node_modules", "!**/data", "!**/.mstro", "!**/.claude"]
  }
}
